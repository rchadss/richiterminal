# Anfossi Terminal — Environment Variables
# Copy this file to .env and fill in any optional keys
# The terminal runs without any keys — these are optional upgrades only

PORT=3000

# Optional: Alpha Vantage (free at alphavantage.co)
# Enables higher-frequency market data as a fallback for yahoo-finance2
# ALPHA_VANTAGE_KEY=your_key_here

# Optional: NewsAPI (free at newsapi.org — development only)
# Adds article headlines from a broader news network
# NEWS_API_KEY=your_key_here
